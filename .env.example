# ================================================================
# Swami Vivekanand Mahavidyalaya — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ================================================================

# NextAuth — REQUIRED
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here_min_32_chars
NEXTAUTH_URL=https://swamivivekanandmahavidyalaya.edu.in

# Admin credentials — REQUIRED
ADMIN_USERNAME=admin
# Generate bcrypt hash: node -e "const b=require('bcryptjs'); console.log(b.hashSync('YourPassword123',12))"
ADMIN_PASSWORD_HASH=$2a$12$your_bcrypt_hash_here
ADMIN_EMAIL=admin@swamivivekanandmahavidyalaya.edu.in

# SMTP (for contact form emails) — OPTIONAL
# You can use Gmail App Password, Brevo, Resend, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password

# Cloudinary (for image/gallery uploads) — OPTIONAL
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================================================================
# For local dev:
#   NEXTAUTH_URL=http://localhost:3000
#   Admin subdomain: add to /etc/hosts → 127.0.0.1 administration.localhost
# ================================================================
